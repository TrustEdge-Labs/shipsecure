# TrustEdge Audit — Production Docker Compose
# Generated by Ansible — do not edit manually
# Images are pre-built by GitHub Actions and pulled from ghcr.io

services:
  backend:
    image: ghcr.io/trustedge-labs/trustedge-backend:latest
    ports:
      - "127.0.0.1:3000:3000"
    env_file:
      - .env
    environment:
      DATABASE_URL: ${DATABASE_URL}
    restart: unless-stopped
    # Graceful shutdown (Phase 24: INF-03) — matches SHUTDOWN_TIMEOUT
    stop_signal: SIGTERM
    stop_grace_period: 90s
    deploy:
      resources:
        limits:
          cpus: '2.0'
          memory: 2G
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  frontend:
    image: ghcr.io/trustedge-labs/trustedge-frontend:latest
    ports:
      - "127.0.0.1:3001:3001"
    environment:
      BACKEND_URL: http://backend:3000
      NEXT_PUBLIC_BACKEND_URL: ${NEXT_PUBLIC_BACKEND_URL}
    restart: unless-stopped
    # Graceful shutdown (Phase 24: INF-03) — matches SHUTDOWN_TIMEOUT
    stop_signal: SIGTERM
    stop_grace_period: 10s
    depends_on:
      - backend
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 1G
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

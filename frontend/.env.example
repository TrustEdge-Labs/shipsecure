# Backend URL (used by Next.js server-side and proxy)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3000

# Clerk Authentication
# Create an application at https://dashboard.clerk.com
# Then get your API keys from: Clerk Dashboard -> API Keys
#
# Publishable key (safe to expose, starts with pk_)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY

# Secret key (keep private, starts with sk_)
CLERK_SECRET_KEY=sk_test_YOUR_SECRET_KEY

# Auth redirect URLs (these are the defaults; customize if needed)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard?source=signup

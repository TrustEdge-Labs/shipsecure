---
# Copy to vault.yml and fill in real values:
#   cp vault.yml.example vault.yml
# vault.yml is gitignored — never committed with real secrets

vault_do_api_token: "REPLACE_WITH_DO_API_TOKEN"
vault_domain_name: "REPLACE_WITH_DOMAIN"
vault_admin_email: "REPLACE_WITH_EMAIL"
vault_deploy_ssh_public_key: "REPLACE_WITH_SSH_PUBLIC_KEY"
vault_ghcr_username: "REPLACE_WITH_GITHUB_USERNAME_OR_ORG"
vault_ghcr_token: "REPLACE_WITH_GITHUB_PAT_READ_PACKAGES"
vault_database_url: "REPLACE_WITH_MANAGED_DB_URL"
vault_resend_api_key: ""
vault_stripe_secret_key: ""
vault_stripe_webhook_secret: ""

# Clerk authentication (Phase 29). Required by env.production.j2.
# Pull these from the Clerk dashboard for the production instance.
vault_clerk_jwks_url: "REPLACE_WITH_CLERK_JWKS_URL"            # https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
vault_clerk_secret_key: "REPLACE_WITH_CLERK_SECRET_KEY"        # sk_live_...
vault_clerk_publishable_key: "REPLACE_WITH_CLERK_PUBLISHABLE_KEY"  # pk_live_...
vault_clerk_webhook_signing_secret: ""                         # whsec_... (optional but recommended)

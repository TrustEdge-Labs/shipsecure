# ShipSecure — Production Environment
# Generated by Ansible — do not edit manually

# ========================================
# CORE CONFIGURATION
# ========================================

# PostgreSQL connection string (REQUIRED)
DATABASE_URL={{ database_url }}

# HTTP server port (REQUIRED)
PORT=3000

# Logging level and filter (REQUIRED)
RUST_LOG=info,shipsecure=info

# ========================================
# OBSERVABILITY CONFIGURATION (Phase 24)
# ========================================

# Log output format (Phase 24: INF-05)
# json = structured JSON output (for production log aggregation)
# Anything else or unset = plain text (for development)
LOG_FORMAT=json

# Shutdown timeout (Phase 23/24 coordination)
# How long to wait for in-flight scans before forced shutdown
# MUST match Docker stop_grace_period in docker-compose.yml
SHUTDOWN_TIMEOUT=90

# Health check DB latency threshold (ms)
# /health/ready reports "degraded" if DB ping exceeds this
HEALTH_DB_LATENCY_THRESHOLD_MS=200

# ========================================
# APPLICATION SETTINGS
# ========================================

# Base URL for this instance (REQUIRED)
SHIPSECURE_BASE_URL=https://{{ domain_name }}

# Frontend URL (REQUIRED)
FRONTEND_URL=https://{{ domain_name }}

# Maximum concurrent scans (REQUIRED)
MAX_CONCURRENT_SCANS=10

# ========================================
# SCANNER CONFIGURATION (OPTIONAL)
# ========================================

# Nuclei binary path (OPTIONAL)
# Installed in Docker image at build time
NUCLEI_BINARY_PATH=/usr/local/bin/nuclei

# testssl.sh binary path (OPTIONAL)
# Installed in Docker image at build time
TESTSSL_BINARY_PATH=/usr/local/bin/testssl.sh

# ========================================
# THIRD-PARTY SERVICES (OPTIONAL)
# ========================================

{% if resend_api_key %}
# Resend API key for email delivery
RESEND_API_KEY={{ resend_api_key }}
{% endif %}

{% if stripe_secret_key %}
# Stripe secret key for payments
STRIPE_SECRET_KEY={{ stripe_secret_key }}
{% endif %}

{% if stripe_webhook_secret %}
# Stripe webhook secret for webhook validation
STRIPE_WEBHOOK_SECRET={{ stripe_webhook_secret }}
{% endif %}

# ========================================
# AUTHENTICATION (Phase 29: Clerk)
# ========================================

# Clerk JWKS URL for JWT verification (REQUIRED for backend)
# Backend uses this to fetch and cache public keys for JWT verification
CLERK_JWKS_URL={{ clerk_jwks_url }}

{% if clerk_secret_key %}
# Clerk Secret Key (REQUIRED for backend webhook verification)
CLERK_SECRET_KEY={{ clerk_secret_key }}
{% endif %}

{% if clerk_webhook_signing_secret %}
# Clerk Webhook Signing Secret (REQUIRED for webhook signature verification)
# Starts with whsec_ — from Clerk Dashboard -> Webhooks -> Endpoint -> Signing Secret
CLERK_WEBHOOK_SIGNING_SECRET={{ clerk_webhook_signing_secret }}
{% endif %}

# ========================================
# DOCKER COMPOSE PRODUCTION VARIABLES
# ========================================

# Frontend public backend URL (used by browser)
NEXT_PUBLIC_BACKEND_URL=https://{{ domain_name }}

# Clerk frontend auth (Phase 29)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY={{ clerk_publishable_key }}
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ========================================
# DOCKER COMPOSE (REQUIRED for production)
# ========================================

# Tells Docker Compose to load both the base and production override files.
# Without this, docker-compose.prod.yml is silently ignored.
# Production: docker-compose.yml:docker-compose.prod.yml
# Development: leave unset (uses docker-compose.yml only)
# COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml

# ========================================
# CORE CONFIGURATION
# ========================================

# PostgreSQL connection string (REQUIRED)
# Format: postgres://username:password@host:port/database
# Development: postgres://shipsecure:shipsecure@localhost:5432/shipsecure_dev
# Production: postgres://shipsecure:STRONG_PASSWORD@db:5432/shipsecure_prod
DATABASE_URL=postgres://shipsecure:shipsecure@localhost:5432/shipsecure_dev

# HTTP server port (REQUIRED)
# The port the backend API will listen on
# Development: 3000
# Production: Usually 3000 (proxied by Nginx)
PORT=3000

# Log output format (OPTIONAL)
# json = structured JSON output (for production log aggregation)
# Anything else or unset = plain text (for development)
# Default: text
# LOG_FORMAT=json

# Graceful shutdown timeout in seconds (OPTIONAL)
# How long to wait for in-flight scans before forced shutdown
# Must match Docker stop_grace_period if using Docker
# Default: 90
# SHUTDOWN_TIMEOUT=90

# Health check DB latency threshold in milliseconds (OPTIONAL)
# /health/ready reports "degraded" if DB ping exceeds this
# Default: 200
# HEALTH_DB_LATENCY_THRESHOLD_MS=200

# Logging level and filter (OPTIONAL)
# If not set, sensible defaults apply (debug for dev, info for production).
# Setting this overrides all defaults.
# Options: error, warn, info, debug, trace
# Format: level,crate_name=level
# Example: info,shipsecure=debug,sqlx=warn
# RUST_LOG=info,shipsecure=debug

# ========================================
# APPLICATION SETTINGS
# ========================================

# Base URL for this instance (REQUIRED)
# Used for generating email links and results URLs
# Development: http://localhost:3001
# Production: https://yourdomain.com
SHIPSECURE_BASE_URL=http://localhost:3001

# Frontend URL (REQUIRED)
# Used for CORS origin allowlist
# Development: http://localhost:3001
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:3001

# Maximum concurrent scans (REQUIRED)
# Controls how many scans can run simultaneously
# Development: 5 (safe for 4GB RAM)
# Production 8GB+: 10-20
MAX_CONCURRENT_SCANS=5

# ========================================
# AUTHENTICATION (REQUIRED)
# ========================================

# Clerk JWKS URL for JWT verification (REQUIRED)
# Used by the backend to verify Clerk session tokens via cached public keys.
# Get from: Clerk Dashboard -> API Keys -> Advanced -> JWKS URL
# Format: https://<your-clerk-instance>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://YOUR_CLERK_INSTANCE.clerk.accounts.dev/.well-known/jwks.json

# ========================================
# SCANNER CONFIGURATION (OPTIONAL)
# ========================================

# Nuclei binary path (OPTIONAL)
# If not set, searches PATH then common install locations
# Scans gracefully skip if Nuclei binary not found
# Example: /usr/local/bin/nuclei
# NUCLEI_BINARY_PATH=

# testssl.sh binary path (OPTIONAL)
# If not set, searches PATH then common install locations
# Scans gracefully skip if testssl.sh binary not found
# Example: /usr/local/bin/testssl.sh
# TESTSSL_BINARY_PATH=

# Custom Nuclei templates directory (OPTIONAL)
# If not set, uses bundled templates at templates/nuclei/
# Use this to provide additional custom templates
# Example: /opt/shipsecure/custom-templates
# SHIPSECURE_TEMPLATES_DIR=

# ========================================
# THIRD-PARTY SERVICES (OPTIONAL)
# ========================================

# Resend API key for email delivery (OPTIONAL)
# If not set, email features are disabled (scans still work)
# Get from: https://resend.com/api-keys
# RESEND_API_KEY=re_...

# ========================================
# CORE CONFIGURATION
# ========================================

# PostgreSQL connection string (REQUIRED)
# Format: postgres://username:password@host:port/database
# Development: postgres://trustedge:trustedge@localhost:5432/trustedge_dev
# Production: postgres://trustedge:STRONG_PASSWORD@db:5432/trustedge_prod
DATABASE_URL=postgres://trustedge:trustedge@localhost:5432/trustedge_dev

# HTTP server port (REQUIRED)
# The port the backend API will listen on
# Development: 3000
# Production: Usually 3000 (proxied by Nginx)
PORT=3000

# Logging level and filter (REQUIRED)
# Options: error, warn, info, debug, trace
# Format: level,crate_name=level
# Example: info,trustedge_audit=debug,sqlx=warn
RUST_LOG=info,trustedge_audit=debug

# ========================================
# APPLICATION SETTINGS
# ========================================

# Base URL for this instance (REQUIRED)
# Used for generating email links and results URLs
# Development: http://localhost:3001
# Production: https://yourdomain.com
TRUSTEDGE_BASE_URL=http://localhost:3001

# Frontend URL (REQUIRED)
# Used for Stripe checkout success/cancel redirects
# Development: http://localhost:3001
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:3001

# Maximum concurrent scans (REQUIRED)
# Controls how many scans can run simultaneously
# Development: 5 (safe for 4GB RAM)
# Production 8GB+: 10-20
MAX_CONCURRENT_SCANS=5

# ========================================
# SCANNER CONFIGURATION (OPTIONAL)
# ========================================

# Nuclei binary path (OPTIONAL)
# If not set, searches PATH then common install locations
# Scans gracefully skip if Nuclei binary not found
# Example: /usr/local/bin/nuclei
# NUCLEI_BINARY_PATH=

# testssl.sh binary path (OPTIONAL)
# If not set, searches PATH then common install locations
# Scans gracefully skip if testssl.sh binary not found
# Example: /usr/local/bin/testssl.sh
# TESTSSL_BINARY_PATH=

# Custom Nuclei templates directory (OPTIONAL)
# If not set, uses bundled templates at templates/nuclei/
# Use this to provide additional custom templates
# Example: /opt/trustedge/custom-templates
# TRUSTEDGE_TEMPLATES_DIR=

# ========================================
# THIRD-PARTY SERVICES (OPTIONAL)
# ========================================

# Resend API key for email delivery (OPTIONAL)
# If not set, email features are disabled (scans still work)
# Get from: https://resend.com/api-keys
# RESEND_API_KEY=re_...

# Stripe secret key for payments (OPTIONAL)
# Required for checkout endpoints to work
# If not set, checkout endpoints return 500 error
# Get from: https://dashboard.stripe.com/apikeys
# Development: Use test key (sk_test_...)
# Production: Use live key (sk_live_...)
# STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook secret for webhook validation (OPTIONAL)
# Required for webhook endpoint to validate signatures
# If not set, webhook endpoint returns 500 error
# Get from: https://dashboard.stripe.com/webhooks
# Development: Use test webhook secret (whsec_...)
# Production: Use live webhook secret
# STRIPE_WEBHOOK_SECRET=whsec_...
